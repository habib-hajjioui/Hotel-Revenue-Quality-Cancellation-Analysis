        "# Completion flag (Check-Out only — verified to exclude No-Shows)\n",
        "df['completed'] = df['reservation_status'] == 'Check-Out'\n",
        "\n",
        "# Lead time buckets\n",
        "def categorize_lead_time(days):\n",
        "    if days <= 2:\n",
        "        return '0-2 days'\n",
        "    elif days <= 7:\n",
        "        return '3-7 days'\n",
        "    elif days <= 30:\n",
        "        return '8-30 days'\n",
        "    else:\n",
        "        return '30+ days'\n",
        "\n",
        "df['lead_time_bucket'] = df['lead_time'].apply(categorize_lead_time)\n",
        "\n",
        "# Date features\n",
        "df['arrival_date'] = pd.to_datetime(\n",
        "    df['arrival_date_year'].astype(str) + '-' +\n",
        "    df['arrival_date_month'] + '-' +\n",
        "    df['arrival_date_day_of_month'].astype(str),\n",
        "    format='%Y-%B-%d', errors='coerce'\n",
        ")\n",
        "df['arrival_month'] = df['arrival_date'].dt.month\n",
        "df['arrival_quarter'] = df['arrival_date'].dt.quarter"
      ],
